{
  "name": "qovf-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "移动端 SPA 外汇交易平台 - 用户端框架底座 (Vue3 + Vite + Pinia + TS)",
  "scripts": {
    "dev": "vite",
    "build": "pnpm check && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "check:lines": "node ../scripts/check-file-lines.mjs src",
    "check": "pnpm typecheck && pnpm check:lines"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "pinia": "^2.3.0",
    "vant": "^4.9.15",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@vant/auto-import-resolver": "^1.2.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "sass": "^1.83.0",
    "typescript": "^5.7.2",
    "unplugin-vue-components": "^28.0.0",
    "vite": "^6.0.5",
    "vue-tsc": "^2.2.0"
  }
}
